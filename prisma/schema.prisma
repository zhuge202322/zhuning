generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model AdminUser {
  id           Int      @id @default(autoincrement())
  username     String   @unique
  passwordHash String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model Category {
  id        Int       @id @default(autoincrement())
  name      String
  slug      String    @unique
  imageUrl  String?
  sortOrder Int       @default(0)
  nameFr    String    @default("")
  nameEs    String    @default("")
  nameAr    String    @default("")
  products  Product[] @relation("ProductCategories")
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
}

model Product {
  id                 Int            @id @default(autoincrement())
  name               String
  slug               String         @unique
  shortDescription   String         @default("")
  description        String         @default("")
  material           String         @default("")
  sourceSku          String         @default("")
  sourceCategory     String         @default("")
  price              Decimal?
  weight             String         @default("")
  packaging          String         @default("")
  stones             String         @default("")
  collection         String         @default("")
  featured           Boolean        @default(false)
  sortOrder          Int            @default(0)
  nameFr             String         @default("")
  nameEs             String         @default("")
  nameAr             String         @default("")
  shortDescriptionFr String         @default("")
  shortDescriptionEs String         @default("")
  shortDescriptionAr String         @default("")
  descriptionFr      String         @default("")
  descriptionEs      String         @default("")
  descriptionAr      String         @default("")
  specs              String         @default("")
  specsFr            String         @default("")
  specsEs            String         @default("")
  specsAr            String         @default("")
  specsPdf           String?
  formula            String         @default("")
  formulaFr          String         @default("")
  formulaEs          String         @default("")
  formulaAr          String         @default("")
  formulaPdf         String?
  images             ProductImage[]
  categories         Category[]     @relation("ProductCategories")
  skus               ProductSku[]
  orderItems         OrderItem[]
  createdAt          DateTime       @default(now())
  updatedAt          DateTime       @updatedAt
}

model ProductImage {
  id        Int      @id @default(autoincrement())
  productId Int
  src       String
  alt       String   @default("")
  sortOrder Int      @default(0)
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
}

model ProductSku {
  id        Int               @id @default(autoincrement())
  productId Int
  name      String
  nameFr    String            @default("")
  nameEs    String            @default("")
  nameAr    String            @default("")
  image     String            @default("")
  price     String            @default("")
  size      String            @default("")
  product   Product           @relation(fields: [productId], references: [id], onDelete: Cascade)
  images    ProductSkuImage[]
}

model ProductSkuImage {
  id        Int        @id @default(autoincrement())
  skuId     Int
  src       String
  sortOrder Int        @default(0)
  sku       ProductSku @relation(fields: [skuId], references: [id], onDelete: Cascade)
}

model Post {
  id             Int      @id @default(autoincrement())
  title          String
  slug           String   @unique
  excerpt        String   @default("")
  content        String   @default("")
  featuredImage  String?
  authorName     String   @default("Muxcor Team")
  date           DateTime @default(now())
  titleFr        String   @default("")
  titleEs        String   @default("")
  titleAr        String   @default("")
  excerptFr      String   @default("")
  excerptEs      String   @default("")
  excerptAr      String   @default("")
  contentFr      String   @default("")
  contentEs      String   @default("")
  contentAr      String   @default("")
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}

model Customer {
  id          Int      @id @default(autoincrement())
  name        String
  email       String   @unique
  phone       String   @default("")
  status      String   @default("Active")
  notes       String   @default("")
  totalOrders Int      @default(0)
  totalSpend  Decimal  @default(0)
  orders      Order[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Order {
  id                Int         @id @default(autoincrement())
  orderNumber       String      @unique
  customerId        Int?
  customerName      String
  customerEmail     String
  status            String      @default("Pending")
  paymentStatus     String      @default("Unpaid")
  fulfillmentStatus String      @default("Unfulfilled")
  currency          String      @default("USD")
  subtotal          Decimal     @default(0)
  shipping          Decimal     @default(0)
  total             Decimal     @default(0)
  notes             String      @default("")
  customer          Customer?   @relation(fields: [customerId], references: [id], onDelete: SetNull)
  items             OrderItem[]
  createdAt         DateTime    @default(now())
  updatedAt         DateTime    @updatedAt
}

model OrderItem {
  id          Int      @id @default(autoincrement())
  orderId     Int
  productId   Int?
  productName String
  sku         String   @default("")
  image       String   @default("")
  quantity    Int      @default(1)
  price       Decimal  @default(0)
  order       Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product     Product? @relation(fields: [productId], references: [id], onDelete: SetNull)
}

model SiteMedia {
  id        Int      @id @default(autoincrement())
  key       String   @unique
  url       String   @default("")
  label     String   @default("")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model PageView {
  id          Int      @id @default(autoincrement())
  visitorId   String   @default("")
  path        String
  source      String   @default("direct")
  referrer    String   @default("")
  device      String   @default("")
  utmSource   String   @default("")
  utmMedium   String   @default("")
  utmCampaign String   @default("")
  isBot       Boolean  @default(false)
  ipHash      String   @default("")
  userAgent   String   @default("")
  createdAt   DateTime @default(now())
}
